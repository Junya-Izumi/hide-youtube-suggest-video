{
  "manifest_version": 3,
  "name": "hide-youtube-suggest-video",
  "version": "1.1.0",
  "description": "youtubeを見ているときに表示されるおすすめ動画を非表示にします。",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "css": [
        "style.css"
      ],
      "run_at":"document_start"
    }
  ]
}